class RecentCounter {
    // create quueue
    Queue<Integer> q;
    public RecentCounter() {
        q = new ArrayDeque<>();
    }
    
    public int ping(int t) {
        // remove req. not within in time
        while(!q.isEmpty() && q.peek() < t-3000){
            q.poll();
        }
        // add if req. comes in time
        q.offer(t);
        // Remaining requests are within time
        return q.size();
    }
}

