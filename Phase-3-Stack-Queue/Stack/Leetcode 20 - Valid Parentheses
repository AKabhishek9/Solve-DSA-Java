// Approach 1 ----------------------------------------------------------------(TC = 4ms)
class Solution {
    public boolean isValid(String s) {
        Stack<Character> st = new Stack<>();
        for(int i = 0; i < s.length(); i++){
            // if there is any open brackets push into the stack
            if(s.charAt(i) == '(' || s.charAt(i) == '[' || s.charAt(i) == '{'){
                st.push(s.charAt(i));
            }
            else{
                if(st.isEmpty()){
                    return false;
                }
                // if there is any closing brackets peek in the stack
                // if bracket found pop it
                if((s.charAt(i) == ')') && (st.peek() == '(') ||
                    (s.charAt(i) == ']') && (st.peek() == '[') ||
                    (s.charAt(i) == '}') && (st.peek() == '{')){
                    st.pop();
                }
                else{
                    // if bracket not found means stack is non empty 
                    // there is closing bracket still present
                    return false;
                }
            }
        }
        if(st.isEmpty()){
            return true;
        }
        return false;
    }
}
