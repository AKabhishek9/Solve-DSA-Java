class MinStack {
    // create global stack variables
    Stack<Integer> st;
    Stack<Integer> minValue;

    public MinStack() {
        st = new Stack<>();
        minValue = new Stack<>();
    }
    
    public void push(int value) {
        // push into stack
        st.push(value);
        // push into min. stack
        if(minValue.isEmpty() || value <= minValue.peek()){
            minValue.push(value);
        }
    }
    
    public void pop() {
        // pop from min. stack first
        if(st.peek().equals(minValue.peek())){
            minValue.pop();
        }
        st.pop();
    }
    
    public int top() {
        return st.peek();
    }
    
    public int getMin() {
        return minValue.peek();
    }
}

