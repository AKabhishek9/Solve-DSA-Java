class Solution {
    public int findGCD(int[] nums) {
        int small = Integer.MAX_VALUE;
        int large = 0;
        // cal. max and min values
        for(int i = 0; i < nums.length; i++){
            small = Math.min(small, nums[i]);
            large = Math.max(large, nums[i]);
        }
        // use Euclidean method to find GCD
        while(large != 0){
            int rem = small%large;
            small = large;
            large = rem;
        }
        return small;
    }
}
