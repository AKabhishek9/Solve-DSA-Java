class Solution {
    public int maxProfit(int[] prices) {
        int toBuy = Integer.MAX_VALUE;
        int toSell = 0;
        for(int i = 0; i < prices.length; i++){
            toBuy = Math.min(toBuy, prices[i]);
            toSell = Math.max(toSell, prices[i] - toBuy);
        }
        return toSell;
    }
}
