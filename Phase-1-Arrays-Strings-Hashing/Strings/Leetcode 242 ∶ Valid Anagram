class Solution {
    public boolean isAnagram(String s, String t) {
        if(s.length() != t.length()){
            return false;
        }
        int frq[] = new int[256];
        for(int i = 0; i < s.length(); i++){
            frq[s.charAt(i)]++;
        }

        for(int i = 0; i < t.length(); i++){
            frq[t.charAt(i)]--;
            if(frq[t.charAt(i)] < 0){
                return false;
            }
        }
        return true;
    }
}
