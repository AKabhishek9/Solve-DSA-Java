class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        if(k <= 1)return 0;
        int cnt = 0;
        int product = 1;
        int left = 0;
        for(int i = 0; i<nums.length; i++){
            product*=nums[i];
            while(product >= k){
                product/=nums[left];
                left++;
            }
            cnt+=i-left+1;
        }
        return cnt;
    }
}
