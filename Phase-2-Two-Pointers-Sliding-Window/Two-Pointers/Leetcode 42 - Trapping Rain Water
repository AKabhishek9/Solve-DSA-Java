// Approach 1 -------------------------------------------------(TC = 1ms)
class Solution {
    public int trap(int[] height) {
        int leftPtr = 0;
        int rightPtr = height.length - 1;
        int leftMax = 0; 
        int rightMax = 0;
        int cnt = 0;
        while(leftPtr < rightPtr){
            if(height[leftPtr] > leftMax){
                leftMax = Math.max(height[leftPtr], leftMax);
            }
            if(height[rightPtr] > rightMax){
                rightMax = Math.max(height[rightPtr], rightMax);
            }
            if(leftMax < rightMax){
                cnt+=leftMax - height[leftPtr];
                leftPtr++;
            }
            else{
                cnt+=rightMax - height[rightPtr];
                rightPtr--;
            }
        }
        return cnt;
    }
}

// Approach 2 ------------------------------------------------(BEST TC = 0ms)
class Solution {
    public int trap(int[] height) {
        int left = 0;
        int right = height.length-1;
        int water = 0;
        int leftMax = height[left];
        int rightMax = height[right];
        
        while(left < right){
            // increase left pointer first if height of left side < right side
            if(leftMax < rightMax){
                left++;
                // store the max height of left side 
                leftMax = Math.max(leftMax, height[left]);
                // if the height of next element in array is small than leftMax
                // increase the water count
                water += leftMax - height[left];
            }
            else{
                // decrease right pointer if height of left side > right side
                right--;
                // store max height of right side
                rightMax = Math.max(rightMax, height[right]);
                // if the height of current right pointer element is < rightMax
                // increase water count
                water += rightMax - height[right];
            }
        }
        return water;
    }
}
