// Approach 1
class Solution{
    public ListNode middleNode(ListNode head){
        if(head == null){
            return null;
        }
        int n = 0;
        ListNode curr = head;
        while(curr != null){
            n++;
            curr = curr.next;
        }

        curr = head;
        for(int i = 0; i < n / 2; i++){
            curr = curr.next;
        }
        return curr;
    }
}

// Approach 2
class Solution {
    public ListNode middleNode(ListNode head) {
        if(head.next == null){
            return head;
        }

        ListNode end = head;
        ListNode mid = head;
        while(end != null && end.next != null){
            mid = mid.next;
            end = end.next.next;
        }
        return mid;
    }
}
